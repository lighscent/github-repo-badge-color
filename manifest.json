{
    "manifest_version": 3,
    "name": "GitHub Repo Visibility Color",
    "author": "xl1te (lighscent)",
    "version": "1.0",
    "description": "Colors repository visibility badges on GitHub.",
    "repository": "https://github.com/lighscent/github-repo-visibility-color",
    "permissions": [
        "scripting"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://github.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}