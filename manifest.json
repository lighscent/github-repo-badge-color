{
    "manifest_version": 3,
    "name": "GRBC - GitHub Repo Badge Color",
    "author": "xl1te (lighscent)",
    "version": "1.1",
    "description": "Add colors to GitHub repository badges.",
    "permissions": [
        "scripting"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://github.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end"
        }
    ]
}